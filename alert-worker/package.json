{
  "name": "tastematter-alert-worker",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply tastematter-alerts --local",
    "db:migrate:remote": "wrangler d1 migrations apply tastematter-alerts --remote",
    "generate-corpus": "tsx scripts/generate-corpus.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "agents": "^0.2.17",
    "ai": "^6.0.87",
    "picomatch": "^4.0.3",
    "zod": "^3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/picomatch": "^4.0.2",
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3",
    "wrangler": "^4"
  }
}
